{
  "compilerOptions": {
    "target": "es6",
    "module": "es6",
    "rootDir": "./src",
    "outDir": "./public",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "resolveJsonModule": true,
    "allowJs": false,
    "lib": ["DOM", "DOM.Iterable", "ES2017"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
